# Copier ce fichier en .env et remplir les valeurs pour votre machine.
# .env est ignoré par git — ne jamais commiter .env directement.

# Chemin vers votre installation Hadoop (obligatoire sur Windows)
# Télécharger winutils + hadoop.dll depuis https://github.com/cdarlint/winutils
HADOOP_HOME=C:\path\to\hadoop

# Exécutable Python pour Spark (optionnel — détecté automatiquement si absent)
# Utile si votre env Spark n'est pas l'env Python actif (ex: venv séparé)
# PYSPARK_PYTHON=C:\path\to\python.exe
# PYSPARK_DRIVER_PYTHON=C:\path\to\python.exe

# Chemin vers le dataset parquet (optionnel — par défaut: data/features/training_dataset)
# DATA_PATH=C:\path\to\data\features\training_dataset
